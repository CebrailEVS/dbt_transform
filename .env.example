# Environment target (dev or prod — always use dev locally)
DBT_TARGET=dev

# BigQuery Configuration
DBT_BIGQUERY_PROJECT=                        # GCP project ID — demander au Data Engineer
DBT_BIGQUERY_KEYFILE=                        # Chemin absolu vers la clé GCP JSON — demander au Data Engineer

# Datasets cibles BigQuery
DBT_BIGQUERY_DATASET_DEV=dev
DBT_BIGQUERY_DATASET_PROD=prod

# Datasets pour les snapshots
DBT_SNAPSHOT_DATASET_DEV=snapshots_dev
DBT_SNAPSHOT_DATASET_PROD=snapshots
